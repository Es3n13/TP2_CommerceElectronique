{
  "ConnectionStrings": {
    "AuthDbConnection": "Server=localhost;Database=AuthService;Integrated Security=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379,password=,ssl=false,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-jwt-key-minimum-32-characters-long",
    "Issuer": "AuthService",
    "Audience": "Services"
  },
  "Redis": {
    "Enabled": true,
    "CachePrefix": "revoked:",
    "DefaultTTLMinutes": 60,
    "ConnectionRetryAttempts": 3,
    "ConnectionRetryDelayMilliseconds": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AuthService.Services.JwtRevocationValidationService": "Debug",
      "AuthService.Middleware.JwtRevocationBearerEvents": "Debug",
      "AuthService.Services.RevokedAccessTokenService": "Information"
    }
  }
}